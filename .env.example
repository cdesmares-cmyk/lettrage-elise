# Variables d'environnement Supabase
# Copiez ce fichier en .env et remplissez vos valeurs.
# Ne jamais committer le fichier .env sur GitHub !

# URL de votre projet Supabase (ex: https://xxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=https://VOTRE_PROJECT_REF.supabase.co

# Clé publique anonyme (anon key) — visible dans Supabase > Settings > API
VITE_SUPABASE_ANON_KEY=VOTRE_ANON_KEY_ICI
